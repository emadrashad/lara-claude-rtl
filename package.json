{
  "name": "lara-claude-rtl-patcher",
  "displayName": "Lara Claude RTL Patcher",
  "description": "Official RTL/BiDi patcher for Claude Code in VS Code with Arabic-friendly mixed-text rendering.",
  "version": "1.0.4",
  "publisher": "lara",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lara-dev/lara-claude-rtl-patcher.git"
  },
  "homepage": "https://github.com/lara-dev/lara-claude-rtl-patcher#readme",
  "bugs": {
    "url": "https://github.com/lara-dev/lara-claude-rtl-patcher/issues"
  },
  "keywords": [
    "claude",
    "rtl",
    "bidi",
    "arabic",
    "vscode",
    "patcher"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:laraClaudeRtlPatcher.apply",
    "onCommand:laraClaudeRtlPatcher.revert",
    "onCommand:laraClaudeRtlPatcher.status"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "laraClaudeRtlPatcher.apply",
        "title": "Lara Claude RTL Patcher: Apply Patch"
      },
      {
        "command": "laraClaudeRtlPatcher.revert",
        "title": "Lara Claude RTL Patcher: Revert Patch"
      },
      {
        "command": "laraClaudeRtlPatcher.status",
        "title": "Lara Claude RTL Patcher: Show Patch Status"
      }
    ]
  },
  "scripts": {
    "build": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npx @vscode/vsce package",
    "publish:marketplace": "npx @vscode/vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.5.4",
    "@vscode/vsce": "^3.2.1"
  }
}
